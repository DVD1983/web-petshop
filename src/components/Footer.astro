---
const currentYear = new Date().getFullYear();
---

<footer class="bg-gradient-to-r from-primary-300 to-accent-200 text-white py-12 px-5 max-md:py-8">
  <div class="max-w-[1200px] mx-auto px-5">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
      <div>
        <div class="flex items-center gap-3 mb-4">
          <img src="/watermarked_img_15087738268608414710.jpg" alt="MILO Logo" class="h-12 w-12 rounded-full object-cover border-2 border-white/40" />
          <span class="font-logo text-2xl font-bold">MILO</span>
        </div>
        <p class="font-body text-sm text-white/80 leading-relaxed">
          Tu pet shop de confianza en Solano. Productos de calidad para la felicidad de tu mascota.
        </p>
      </div>

      <div>
        <h4 class="font-body font-bold text-sm uppercase tracking-wider mb-4 text-white/90">Navegación</h4>
        <ul class="space-y-2 list-none p-0">
          <li><a href="#inicio" class="font-body text-sm text-white/70 no-underline transition-colors duration-300 hover:text-white">Inicio</a></li>
          <li><a href="#nosotros" class="font-body text-sm text-white/70 no-underline transition-colors duration-300 hover:text-white">Nosotros</a></li>
          <li><a href="#productos" class="font-body text-sm text-white/70 no-underline transition-colors duration-300 hover:text-white">Productos</a></li>
          <li><a href="#contacto" class="font-body text-sm text-white/70 no-underline transition-colors duration-300 hover:text-white">Contacto</a></li>
        </ul>
      </div>

      <div>
        <h4 class="font-body font-bold text-sm uppercase tracking-wider mb-4 text-white/90">Redes Sociales</h4>
        <div class="flex gap-3">
          <a href="https://www.instagram.com/milo.solano.petshop" target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-white/15 flex items-center justify-center text-white no-underline transition-all duration-300 hover:bg-white/30 hover:scale-110" aria-label="Instagram">
            <i class="fab fa-instagram text-lg"></i>
          </a>
          <a href="https://wa.me/5491131628169?text=hola%20quiero%20informacion%20asi%20puedo%20mimar%20a%20mi%20mascota.%20Gracias." target="_blank" rel="noopener noreferrer" class="w-10 h-10 rounded-full bg-white/15 flex items-center justify-center text-white no-underline transition-all duration-300 hover:bg-white/30 hover:scale-110" aria-label="WhatsApp">
            <i class="fab fa-whatsapp text-lg"></i>
          </a>
        </div>
        <div class="mt-4">
          <p class="font-body text-sm text-white/70">
            <i class="fas fa-phone mr-2"></i>11-3162-8169
          </p>
          <p class="font-body text-sm text-white/70 mt-1">
            <i class="fas fa-map-marker-alt mr-2"></i>Solano, Buenos Aires
          </p>
        </div>
      </div>
    </div>

    <div class="border-t border-white/20 pt-6 text-center">
      <p class="font-body font-semibold text-sm text-white/80">
        &copy; {currentYear} <span class="font-bold text-white">MILO Pet Shop</span>. Todos los derechos reservados.
      </p>
    </div>
  </div>
</footer>
