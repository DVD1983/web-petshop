---
import { categories } from '../data/productos';

const { id } = Astro.props;
---

<section id={id} class="py-[70px] px-5 bg-white max-md:py-12 max-md:px-4">
  <div class="max-w-[1200px] mx-auto px-5">
    <h2 class="text-center text-4xl font-black text-primary-500 mb-10 tracking-wide max-md:text-2xl after:block after:w-[70px] after:h-1 after:bg-gradient-to-r after:from-accent-100 after:via-primary-300 after:to-accent-200 after:mx-auto after:mt-3 after:rounded-sm">
      Nuestros Productos
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 max-sm:grid-cols-1 max-md:grid-cols-2">
      {categories.map((cat) => {
        return (
          <a
            href={`/productos/${cat.slug}`}
            class="block rounded-xl px-5 py-8 text-center shadow-sm transition-all duration-400 hover:-translate-y-2 hover:shadow-md relative overflow-hidden no-underline"
            style={`background: ${cat.gradient}`}
          >
            <img src={cat.image} alt={cat.name} class="block w-40 h-40 object-cover rounded-2xl mx-auto mb-4 relative z-10" />
            <h3 class="font-body text-xl font-bold text-gray-800 mb-2 relative z-10">{cat.name}</h3>
            <p class="font-body text-sm text-gray-500 leading-relaxed font-medium relative z-10">{cat.description}</p>
            <span class="inline-block mt-3 px-4 py-1.5 rounded-full bg-primary-500 text-white font-body font-bold text-xs relative z-10 transition-all duration-300 hover:bg-primary-400">
              Explorar <i class="fas fa-arrow-right ml-1 text-xs"></i>
            </span>
          </a>
        );
      })}
    </div>
  </div>
</section>
