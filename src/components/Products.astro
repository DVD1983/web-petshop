---
import { getAllCategories } from '../lib/storage';

const categories = await getAllCategories();
const { id } = Astro.props;
---

<section id={id} class="py-[80px] px-5 bg-white max-md:py-16 max-md:px-4">
  <div class="max-w-[1200px] mx-auto px-5">
    <h2 class="text-center text-4xl font-black text-primary-500 mb-4 tracking-wide max-md:text-2xl after:block after:w-[70px] after:h-1 after:bg-gradient-to-r after:from-accent-100 after:via-primary-300 after:to-accent-200 after:mx-auto after:mt-3 after:rounded-sm">
      Nuestros Productos
    </h2>
    <p class="text-center font-body text-gray-500 mb-12 text-base">Elegí la categoría y descubrí todo lo que tenemos para tu mascota</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 max-md:grid-cols-2 max-md:gap-5 max-sm:grid-cols-1">
      {categories.map((cat, i) => {
        return (
          <a
            href={`/productos/${cat.slug}`}
            class="group block rounded-2xl px-6 py-10 text-center shadow-sm transition-all duration-400 hover:-translate-y-3 hover:shadow-xl relative overflow-hidden no-underline border border-transparent hover:border-white/50"
            style={`background: ${cat.gradient}`}
          >
            <div class="absolute inset-0 bg-white/0 group-hover:bg-white/10 transition-all duration-300"></div>
            <div class="w-40 h-40 mx-auto mb-5 relative z-10 bg-white/60 group-hover:bg-white/80 rounded-2xl flex items-center justify-center p-4 transition-all duration-300 group-hover:scale-105 group-hover:shadow-md">
              <img src={cat.image} alt={cat.name} class="block w-full h-full object-contain mix-blend-multiply" loading="lazy" />
            </div>
            <h3 class="font-body text-xl font-bold text-gray-800 mb-2 relative z-10">{cat.name}</h3>
            <p class="font-body text-sm text-gray-500 leading-relaxed font-medium relative z-10 mb-4">{cat.description}</p>
            <span class="inline-flex items-center gap-1.5 px-5 py-2 rounded-full bg-primary-500 text-white font-body font-bold text-xs relative z-10 transition-all duration-300 group-hover:bg-primary-400 group-hover:shadow-md">
              Explorar <i class="fas fa-arrow-right text-xs transition-transform duration-300 group-hover:translate-x-1"></i>
            </span>
          </a>
        );
      })}
    </div>
  </div>
</section>
