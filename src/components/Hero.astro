---
const { id } = Astro.props;
---

<section
  id={id}
  class="mt-[80px] bg-gradient-to-br from-primary-50 via-primary-300 to-primary-400 via-70% to-accent-200 text-white text-center px-5 py-[120px] relative overflow-hidden max-md:mt-[64px] max-md:py-24 max-md:px-4"
>
  <div
    class="absolute -top-1/2 -left-1/2 w-[200%] h-[200%] bg-[radial-gradient(circle_at_30%_50%,rgba(255,255,255,0.12)_0%,transparent_60%)] animate-[heroGlow_6s_ease-in-out_infinite_alternate] pointer-events-none"
  ></div>

  <span class="absolute inset-0 flex items-center justify-center select-none pointer-events-none overflow-hidden max-md:hidden">
    <span class="font-logo text-[clamp(8rem,30vw,20rem)] font-medium text-white/[0.04] -rotate-6 animate-[floatSlow_8s_ease-in-out_infinite]">
      MILO
    </span>
  </span>

  <div class="max-w-[1200px] mx-auto px-5 relative">
    <div class="inline-flex items-center gap-2 px-5 py-2 rounded-full bg-white/15 backdrop-blur-sm mb-6 border border-white/20 animate-[fadeSlideDown_0.8s_ease-out_both]">
      <span class="text-sm">🐾</span>
      <span class="font-body text-sm font-semibold tracking-wide">Tu pet shop de confianza en Solano</span>
    </div>

    <h1
      class="font-logo text-[clamp(3rem,8vw,6rem)] font-medium uppercase bg-gradient-to-r from-white to-primary-50 bg-clip-text text-transparent leading-tight animate-[fadeSlideUp_0.8s_ease-out_0.2s_both]"
    >
      MILO
    </h1>

    <p class="font-body text-2xl mt-4 font-semibold opacity-95 max-md:text-lg animate-[fadeSlideUp_0.8s_ease-out_0.4s_both]">
      Todo lo que tu mascota necesita, con el amor que se merece
    </p>

    <div class="flex items-center justify-center gap-4 mt-10 flex-wrap animate-[fadeSlideUp_0.8s_ease-out_0.6s_both]">
      <a
        href="#productos"
        class="inline-flex items-center gap-2.5 px-10 py-4 bg-white text-primary-500 font-body font-bold text-base rounded-[50px] shadow-lg transition-all duration-300 hover:-translate-y-1 hover:shadow-xl no-underline"
      >
        <i class="fas fa-shopping-bag text-sm"></i>
        Ver productos
      </a>
      <a
        href="https://wa.me/5491131628169?text=hola%20quiero%20informacion%20asi%20puedo%20mimar%20a%20mi%20mascota.%20Gracias."
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2.5 px-10 py-4 bg-white/15 backdrop-blur-sm text-white font-body font-bold text-base rounded-[50px] border border-white/30 transition-all duration-300 hover:-translate-y-1 hover:bg-white/25 hover:shadow-lg no-underline"
      >
        <i class="fab fa-whatsapp text-lg"></i>
        WhatsApp
      </a>
    </div>

    <div class="flex items-center justify-center gap-8 mt-14 animate-[fadeSlideUp_0.8s_ease-out_0.8s_both] max-md:gap-5 max-md:flex-wrap">
      <div class="text-center">
        <p class="font-logo text-3xl font-bold max-md:text-2xl">6+</p>
        <p class="font-body text-xs opacity-80 font-semibold tracking-wide mt-1">Categorías</p>
      </div>
      <div class="w-px h-10 bg-white/30"></div>
      <div class="text-center">
        <p class="font-logo text-3xl font-bold max-md:text-2xl">30+</p>
        <p class="font-body text-xs opacity-80 font-semibold tracking-wide mt-1">Productos</p>
      </div>
      <div class="w-px h-10 bg-white/30"></div>
      <div class="text-center">
        <p class="font-logo text-3xl font-bold max-md:text-2xl">24h</p>
        <p class="font-body text-xs opacity-80 font-semibold tracking-wide mt-1">Envíos</p>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes heroGlow {
    0% { transform: translate(0, 0); }
    100% { transform: translate(5%, 5%); }
  }
  @keyframes floatSlow {
    0%, 100% { transform: translateY(0) rotate(-6deg); }
    50% { transform: translateY(-20px) rotate(-6deg); }
  }
  @keyframes fadeSlideUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeSlideDown {
    from { opacity: 0; transform: translateY(-20px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
