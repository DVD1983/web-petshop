---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import { getProductsByCategory, getCategoryBySlug } from '../../lib/storage';

const { categoria } = Astro.params;
const slug = categoria!;
const category = await getCategoryBySlug(slug);
const products = await getProductsByCategory(slug);

if (!category) {
  return Astro.redirect('/');
}
---

<Layout title={`${category.name} - MILO Pet Shop`}>
  <Navbar />

  <section class="mt-[86px] bg-gradient-to-br from-purple-50 via-pink-50 to-primary-50 text-gray-700 px-5 pt-28 pb-16 relative overflow-hidden max-md:mt-[66px] max-md:pt-20 max-md:pb-12">
    <div class="max-w-[1200px] mx-auto px-5 relative">
      <a href="/#productos" class="inline-flex items-center gap-2.5 px-5 py-2.5 rounded-full bg-primary-400 text-white font-body font-bold text-sm mb-8 transition-all duration-300 no-underline border border-primary-300 hover:bg-primary-500 hover:border-primary-400 hover:shadow-lg hover:shadow-primary-300/30 hover:-translate-y-0.5">
        <i class="fas fa-arrow-left text-xs"></i> Volver a productos
      </a>
      <h1 class="font-logo text-5xl font-bold text-primary-400 max-md:text-3xl">{category.name}</h1>
      <p class="font-body text-lg mt-2 opacity-80 max-md:text-base">{category.description}</p>
    </div>
  </section>

  <section class="py-[70px] px-5 bg-white max-md:py-12 max-md:px-4">
    <div class="max-w-[1200px] mx-auto px-5">
      {products.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 max-md:gap-6">
          {products.map((product) => (
            <div class="rounded-2xl bg-white border border-gray-100 shadow-sm overflow-hidden transition-all duration-300 hover:-translate-y-2 hover:shadow-xl flex flex-col">
              <div class="aspect-square overflow-hidden bg-gray-50 flex items-center justify-center p-6 border-b border-gray-100">
                <img src={product.image} alt={product.name} class="w-full h-full object-contain mix-blend-multiply" loading="lazy" />
              </div>
              <div class="p-5 flex flex-col flex-1">
                <h3 class="font-logo text-lg font-bold text-gray-800 mb-2">{product.name}</h3>
                <p class="font-body text-sm text-gray-500 leading-relaxed mb-3">{product.description}</p>
                {product.specs.length > 0 && (
                  <div class="mb-4">
                    <p class="font-body text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1.5">Ficha técnica</p>
                    <div class="flex flex-wrap gap-1.5">
                      {product.specs.map((spec) => (
                        <span class="inline-block px-2.5 py-1 bg-primary-50 text-primary-500 font-body text-xs font-semibold rounded-full">{spec}</span>
                      ))}
                    </div>
                  </div>
                )}
                <div class="mt-auto flex items-center justify-between pt-3 border-t border-gray-50">
                  <div>
                    <span class="font-logo text-xl font-bold text-primary-500">{new Intl.NumberFormat('es-AR', { style: 'currency', currency: 'ARS', minimumFractionDigits: 0 }).format(product.price).replace('ARS', '$').trim()}</span>
                    {product.stock !== undefined && product.stock < 5 && product.stock > 0 && (
                      <p class="text-xs text-yellow-600 font-semibold mt-0.5">Últimas {product.stock} unidades</p>
                    )}
                    {product.stock !== undefined && product.stock === 0 && (
                      <p class="text-xs text-red-500 font-semibold mt-0.5">Sin stock</p>
                    )}
                  </div>
                  <button
                    class="add-to-cart px-5 py-2.5 rounded-full bg-primary-500 text-white font-body font-bold text-sm shadow-md transition-all duration-300 hover:-translate-y-0.5 hover:shadow-lg cursor-pointer border-none"
                    data-product-id={product.id}
                    data-product-name={product.name}
                    data-product-price={product.price}
                    data-product-image={product.image}
                    disabled={product.stock === 0}
                    style={product.stock === 0 ? 'opacity:0.5;cursor:not-allowed' : ''}
                  >
                    {product.stock === 0 ? 'Sin stock' : 'Agregar'} <i class="fas fa-plus ml-1 text-xs"></i>
                  </button>
                </div>
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div class="text-center py-20">
          <p class="font-body text-gray-400 text-lg">Próximamente más productos</p>
        </div>
      )}
    </div>
  </section>
</Layout>

<script>
  import { addToCart } from '../../scripts/cart';

  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.add-to-cart').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = btn.dataset.productId;
        const name = btn.dataset.productName;
        const price = parseInt(btn.dataset.productPrice);
        const image = btn.dataset.productImage;
        addToCart(id, name, price, image);

        const originalText = btn.innerHTML;
        btn.innerHTML = '✓ Agregado';
        btn.classList.remove('bg-primary-500');
        btn.classList.add('bg-green-500');
        setTimeout(() => {
          btn.innerHTML = originalText;
          btn.classList.remove('bg-green-500');
          btn.classList.add('bg-primary-500');
        }, 1500);
      });
    });
  });
</script>
