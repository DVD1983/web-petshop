---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import { getProductsByCategory, getCategoryBySlug } from '../../lib/storage';

const { categoria } = Astro.params;
const slug = categoria!;
const category = await getCategoryBySlug(slug);
const products = await getProductsByCategory(slug);

if (!category) {
  return Astro.redirect('/');
}
---

<Layout title={`${category.name} - MILO Pet Shop`}>
  <Navbar />

  <section class="mt-[80px] bg-gradient-to-br from-purple-50 via-pink-50 to-primary-50 text-gray-700 px-5 pt-28 pb-16 relative overflow-hidden max-md:mt-[64px] max-md:pt-20 max-md:pb-12">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_70%_30%,rgba(79,195,247,0.08)_0%,transparent_60%)] pointer-events-none"></div>
    <div class="max-w-[1200px] mx-auto px-5 relative">
      <a href="/#productos" class="inline-flex items-center gap-2.5 px-5 py-2.5 rounded-full bg-primary-400 text-white font-body font-bold text-sm mb-8 transition-all duration-300 no-underline border border-primary-300 hover:bg-primary-500 hover:border-primary-400 hover:shadow-lg hover:shadow-primary-300/30 hover:-translate-y-0.5">
        <i class="fas fa-arrow-left text-xs"></i> Volver a productos
      </a>
      <h1 class="font-logo text-5xl font-bold text-primary-400 max-md:text-3xl">{category.name}</h1>
      <p class="font-body text-lg mt-2 opacity-80 max-md:text-base">{category.description}</p>
    </div>
  </section>

  <section class="py-[70px] px-5 bg-white max-md:py-12 max-md:px-4">
    <div class="max-w-[1200px] mx-auto px-5">
      {products.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 max-md:gap-6">
          {products.map((product) => (
            <div class="group rounded-2xl bg-white border border-gray-100 shadow-sm overflow-hidden transition-all duration-300 hover:-translate-y-2 hover:shadow-xl flex flex-col">
              <div class="aspect-square overflow-hidden bg-gray-50 flex items-center justify-center p-6 border-b border-gray-100 relative">
                <img src={product.image} alt={product.name} class="w-full h-full object-contain mix-blend-multiply transition-transform duration-500 group-hover:scale-110" loading="lazy" />
                {product.stock !== undefined && product.stock < 5 && product.stock > 0 && (
                  <span class="absolute top-3 right-3 bg-yellow-400 text-yellow-900 text-[10px] font-bold px-2.5 py-1 rounded-full">Últimas {product.stock}</span>
                )}
                {product.stock !== undefined && product.stock === 0 && (
                  <span class="absolute top-3 right-3 bg-red-400 text-white text-[10px] font-bold px-2.5 py-1 rounded-full">Sin stock</span>
                )}
              </div>
              <div class="p-5 flex flex-col flex-1">
                <h3 class="font-logo text-lg font-bold text-gray-800 mb-2">{product.name}</h3>
                <p class="font-body text-sm text-gray-500 leading-relaxed mb-3">{product.description}</p>
                {product.specs.length > 0 && (
                  <div class="mb-4">
                    <p class="font-body text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1.5">Ficha técnica</p>
                    <div class="flex flex-wrap gap-1.5">
                      {product.specs.map((spec) => (
                        <span class="inline-block px-2.5 py-1 bg-primary-50 text-primary-500 font-body text-xs font-semibold rounded-full">{spec}</span>
                      ))}
                    </div>
                  </div>
                )}
                <div class="mt-auto flex flex-col items-center gap-3 pt-3 border-t border-gray-50">
                  <a
                    href={`https://wa.me/5491131628169?text=${encodeURIComponent('Hola, quiero consultar por: ' + product.name)}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="w-full flex items-center justify-center gap-2 px-5 py-2.5 rounded-full bg-green-500 text-white font-body font-bold text-sm shadow-md transition-all duration-300 hover:-translate-y-0.5 hover:shadow-lg hover:bg-green-600 no-underline"
                  >
                    <i class="fab fa-whatsapp text-base"></i> Consultar
                  </a>
                </div>
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div class="text-center py-20">
          <i class="fas fa-box-open text-5xl text-gray-200 mb-4"></i>
          <p class="font-body text-gray-400 text-lg">Próximamente más productos</p>
        </div>
      )}
    </div>
  </section>
</Layout>
