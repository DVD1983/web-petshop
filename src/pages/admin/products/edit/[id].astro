---
import AdminLayout from '../../../../layouts/AdminLayout.astro';
import { getProductById, getAllCategories } from '../../../../lib/storage';

const { id } = Astro.params;
const product = await getProductById(id!);
const categories = await getAllCategories();

if (!product) {
  return Astro.redirect('/admin');
}
---

<AdminLayout title="Editar Producto - MILO Admin">
  <div class="mb-8">
    <a href="/admin" class="text-sm text-gray-400 hover:text-primary-400 transition-colors">
      <i class="fas fa-arrow-left mr-1"></i> Volver a productos
    </a>
    <h1 class="text-2xl font-bold text-gray-800 mt-2">Editar Producto</h1>
    <p class="text-gray-500 mt-1">ID: {product.id}</p>
  </div>

  <div class="card max-w-2xl">
    <form id="productForm" class="flex flex-col gap-5">
      <input type="hidden" name="id" value={product.id} />

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label for="categorySlug" class="block text-sm font-semibold text-gray-600 mb-1.5">Categoría *</label>
          <select id="categorySlug" name="categorySlug" required class="input-field">
            {categories.map(cat => (
              <option value={cat.slug} selected={cat.slug === product.categorySlug}>{cat.name}</option>
            ))}
          </select>
        </div>
        <div>
          <label for="price" class="block text-sm font-semibold text-gray-600 mb-1.5">Precio ($) *</label>
          <input type="number" id="price" name="price" required min="0" class="input-field" value={product.price} />
        </div>
      </div>

      <div>
        <label for="name" class="block text-sm font-semibold text-gray-600 mb-1.5">Nombre del producto *</label>
        <input type="text" id="name" name="name" required class="input-field" value={product.name} />
      </div>

      <div>
        <label for="description" class="block text-sm font-semibold text-gray-600 mb-1.5">Descripción</label>
        <textarea id="description" name="description" rows="3" class="input-field">{product.description}</textarea>
      </div>

      <div>
        <label for="specs" class="block text-sm font-semibold text-gray-600 mb-1.5">Especificaciones</label>
        <input type="text" id="specs" name="specs" class="input-field" value={product.specs.join(', ')} />
        <p class="text-xs text-gray-400 mt-1">Separadas por coma</p>
      </div>

      <div>
        <label for="image" class="block text-sm font-semibold text-gray-600 mb-1.5">URL de imagen</label>
        <input type="url" id="image" name="image" class="input-field" value={product.image} />
      </div>

      <p id="errorMsg" class="text-red-500 text-sm hidden"></p>

      <div class="flex gap-3 pt-2">
        <button type="submit" class="btn-primary">Guardar cambios</button>
        <a href="/admin" class="btn-secondary">Cancelar</a>
      </div>
    </form>
  </div>

  <script>
    document.getElementById('productForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const errorMsg = document.getElementById('errorMsg');
      errorMsg.classList.add('hidden');

      const specsRaw = document.getElementById('specs').value;
      const specs = specsRaw ? specsRaw.split(',').map(s => s.trim()).filter(Boolean) : [];

      const data = {
        name: document.getElementById('name').value.trim(),
        description: document.getElementById('description').value.trim(),
        specs,
        price: Number(document.getElementById('price').value),
        image: document.getElementById('image').value.trim() || 'https://placehold.co/400x400/ccc/ffffff?text=Producto',
        categorySlug: document.getElementById('categorySlug').value,
      };

      const productId = document.querySelector('input[name="id"]').value;

      try {
        const res = await fetch(`/api/products/${productId}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        if (res.ok) {
          window.location.href = '/admin';
        } else {
          const err = await res.json();
          errorMsg.textContent = err.error || 'Error al guardar los cambios';
          errorMsg.classList.remove('hidden');
        }
      } catch {
        errorMsg.textContent = 'Error de conexión';
        errorMsg.classList.remove('hidden');
      }
    });
  </script>
</AdminLayout>
