---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getAllCategories } from '../../../lib/storage';

const categories = await getAllCategories();
---

<AdminLayout title="Nuevo Producto - MILO Admin">
  <div class="mb-8">
    <a href="/admin" class="text-sm text-gray-400 hover:text-primary-400 transition-colors">
      <i class="fas fa-arrow-left mr-1"></i> Volver a productos
    </a>
    <h1 class="text-2xl font-bold text-gray-800 mt-2">Nuevo Producto</h1>
  </div>

  <div class="card max-w-2xl">
    <form id="productForm" class="flex flex-col gap-5">
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label for="id" class="block text-sm font-semibold text-gray-600 mb-1.5">ID *</label>
          <input type="text" id="id" name="id" required class="input-field" placeholder="ej: nuevo-producto" />
          <p class="text-xs text-gray-400 mt-1">Identificador único (sin espacios)</p>
        </div>
        <div>
          <label for="categorySlug" class="block text-sm font-semibold text-gray-600 mb-1.5">Categoría *</label>
          <select id="categorySlug" name="categorySlug" required class="input-field">
            <option value="">Seleccionar categoría...</option>
            {categories.map(cat => (
              <option value={cat.slug}>{cat.name}</option>
            ))}
          </select>
        </div>
      </div>

      <div>
        <label for="name" class="block text-sm font-semibold text-gray-600 mb-1.5">Nombre del producto *</label>
        <input type="text" id="name" name="name" required class="input-field" placeholder="Ej: ProPlan Adultos Raza Pequeña" />
      </div>

      <div>
        <label for="description" class="block text-sm font-semibold text-gray-600 mb-1.5">Descripción</label>
        <textarea id="description" name="description" rows="3" class="input-field" placeholder="Descripción del producto..."></textarea>
      </div>

      <div>
        <label for="specs" class="block text-sm font-semibold text-gray-600 mb-1.5">Especificaciones</label>
        <input type="text" id="specs" name="specs" class="input-field" placeholder="Ej: 3 kg, Pollo real, Sin colorantes" />
        <p class="text-xs text-gray-400 mt-1">Separadas por coma</p>
      </div>

      <div class="grid grid-cols-3 gap-4">
        <div>
          <label for="price" class="block text-sm font-semibold text-gray-600 mb-1.5">Precio ($) *</label>
          <input type="number" id="price" name="price" required min="0" class="input-field" placeholder="12500" />
        </div>
        <div>
          <label for="stock" class="block text-sm font-semibold text-gray-600 mb-1.5">Stock</label>
          <input type="number" id="stock" name="stock" min="0" class="input-field" placeholder="10" value="0" />
        </div>
      </div>

      <div>
        <label class="block text-sm font-semibold text-gray-600 mb-1.5">Imagen</label>
        <div class="flex flex-col gap-3">
          <div class="flex items-center gap-3">
            <label class="cursor-pointer px-4 py-2.5 rounded-xl border border-gray-300 hover:bg-gray-50 transition-colors text-sm text-gray-600">
              <i class="fas fa-upload mr-1"></i> Subir archivo
              <input type="file" id="imageFile" accept="image/jpeg,image/png,image/webp,image/gif" class="hidden" />
            </label>
            <span class="text-gray-400 text-sm">o</span>
            <input type="url" id="image" name="image" class="input-field flex-1" placeholder="https://..." />
          </div>
          <div id="imagePreview" class="hidden">
            <img src="" alt="preview" class="w-24 h-24 rounded-xl object-cover border border-gray-200" />
          </div>
          <p class="text-xs text-gray-400">Subí un archivo o ingresá una URL. Máx 5MB.</p>
        </div>
      </div>

      <p id="errorMsg" class="text-red-500 text-sm hidden"></p>

      <div class="flex gap-3 pt-2">
        <button type="submit" class="btn-primary">Crear producto</button>
        <a href="/admin" class="btn-secondary">Cancelar</a>
      </div>
    </form>
  </div>

  <script>
    const imageFile = document.getElementById('imageFile');
    const imageUrl = document.getElementById('image');
    const imagePreview = document.getElementById('imagePreview');
    const previewImg = imagePreview.querySelector('img');

    imageFile.addEventListener('change', async (e) => {
      const file = e.target.files?.[0];
      if (!file) return;

      if (file.size > 5 * 1024 * 1024) {
        showToast('La imagen no puede superar los 5MB', 'error');
        imageFile.value = '';
        return;
      }

      const reader = new FileReader();
      reader.onload = (ev) => {
        previewImg.src = ev.target.result;
        imagePreview.classList.remove('hidden');
        imageUrl.value = ev.target.result;
      };
      reader.readAsDataURL(file);
    });

    imageUrl.addEventListener('input', () => {
      if (imageUrl.value) {
        previewImg.src = imageUrl.value;
        imagePreview.classList.remove('hidden');
        imageFile.value = '';
      } else {
        imagePreview.classList.add('hidden');
      }
    });

    document.getElementById('productForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const errorMsg = document.getElementById('errorMsg');
      errorMsg.classList.add('hidden');
      const submitBtn = e.target.querySelector('button[type="submit"]');
      submitBtn.disabled = true;
      submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Creando...';

      const specsRaw = document.getElementById('specs').value;
      const specs = specsRaw ? specsRaw.split(',').map(s => s.trim()).filter(Boolean) : [];

      const data = {
        id: document.getElementById('id').value.trim(),
        name: document.getElementById('name').value.trim(),
        description: document.getElementById('description').value.trim(),
        specs,
        price: Number(document.getElementById('price').value),
        stock: Number(document.getElementById('stock').value) || 0,
        image: imageUrl.value.trim() || 'https://placehold.co/400x400/ccc/ffffff?text=Producto',
        categorySlug: document.getElementById('categorySlug').value,
      };

      try {
        const res = await fetch('/api/products', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        if (res.ok) {
          showToast('Producto creado con éxito', 'success');
          setTimeout(() => window.location.href = '/admin', 600);
        } else {
          const err = await res.json();
          errorMsg.textContent = err.error || 'Error al crear el producto';
          errorMsg.classList.remove('hidden');
          submitBtn.disabled = false;
          submitBtn.textContent = 'Crear producto';
        }
      } catch {
        errorMsg.textContent = 'Error de conexión';
        errorMsg.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Crear producto';
      }
    });
  </script>
</AdminLayout>
