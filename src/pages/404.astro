---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Página no encontrada - MILO Pet Shop">
  <div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-primary-50 via-white to-accent-50 px-5">
    <div class="text-center max-w-lg">
      <div class="text-8xl font-logo font-extrabold text-primary-300 mb-4" style="font-family: 'Baloo 2', sans-serif;">404</div>
      <h1 class="text-3xl font-bold text-gray-800 mb-3">Página no encontrada</h1>
      <p class="text-gray-500 mb-8">La página que buscás no existe o fue movida. Revisá el link o volvé al inicio.</p>
      <a href="/" class="inline-flex items-center gap-2 bg-primary-400 text-white px-8 py-3 rounded-full font-semibold hover:bg-primary-500 transition-all hover:shadow-lg hover:-translate-y-0.5 no-underline">
        <i class="fas fa-home"></i>
        Volver al inicio
      </a>
    </div>
  </div>
</Layout>
